# ─── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database (support/auth — only used when DATA_BACKEND=local) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marzam_mvp
DB_USER=postgres
DB_PASSWORD=changeme

# ─── JWT ───────────────────────────────────────────────────────────
# IMPORTANT: replace with a cryptographically strong secret for production
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=8h

# ─── Data Backend ──────────────────────────────────────────────────
DATA_BACKEND=external
EXTERNAL_DATA_PROVIDER=sql
EXTERNAL_POI_TABLE=ingestion.ing_poi_farmacias_ecatepec
EXTERNAL_FIELD_SURVEY_TABLE=ingestion.field_survey_pharmacy
EXTERNAL_DEVICE_LOCATIONS_TABLE=ingestion.device_locations
POI_CATALOG_PATH=./src/public/data/ecatepec-demo.json

# ─── Virtual Auth Directory (DATA_BACKEND=external) ───────────────
AUTH_DIRECTORY_PROVIDER=virtual
MANAGER_ID=mgr001
MANAGER_EMAIL=manager@marzam.mx
MANAGER_PASSWORD=Marzam2026!
MANAGER_NAME=Manager Ecatepec
FIELD_REP_COUNT=50
FIELD_REP_ID_PREFIX=rep
FIELD_REP_EMAIL_PREFIX=rep
FIELD_REP_EMAIL_DOMAIN=marzam.mx
FIELD_REP_NAME_PREFIX=Pilot Rep
FIELD_REP_DEFAULT_PASSWORD=Rep2026!

# ─── Photo Storage ────────────────────────────────────────────────
PHOTO_STORAGE_PROVIDER=gcs
PHOTO_STORAGE_DIR=./uploads/photos

# ─── Google Cloud Storage ─────────────────────────────────────────
GCP_PROJECT_ID=blackprint-infra
MARZAM_EVIDENCE_GCS_BUCKET=blackprint-media
MARZAM_EVIDENCE_GCS_FOLDER=marzam/verificaciones/photos
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com
GCS_MAKE_OBJECTS_PUBLIC=false
GCS_SIGNED_URL_TTL_MINUTES=20

# ─── BigQuery / GCS Service Account ──────────────────────────────
BQ_PROJECT_ID=
BQ_SERVICE_ACCOUNT_JSON=

# ─── External SQL Runtime ─────────────────────────────────────────
EXTERNAL_DB_HOST=
EXTERNAL_DB_PORT=5432
EXTERNAL_DB_NAME=
EXTERNAL_DB_USER=
EXTERNAL_DB_PASSWORD=
EXTERNAL_DB_SSL=false

# ─── Schema Maps (optional) ──────────────────────────────────────
EXTERNAL_POI_SCHEMA_MAP={}
EXTERNAL_FIELD_SURVEY_SCHEMA_MAP={}
EXTERNAL_DEVICE_LOCATIONS_SCHEMA_MAP={}

# ─── Google Maps ──────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ─── GPS / Tracking ──────────────────────────────────────────────
GPS_PING_INTERVAL_SECONDS=30
GPS_RETENTION_DAYS=30

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL=info
